# Test environment variables for Playwright E2E tests
# Get these from your TMDB account

# Required: A valid TMDB session ID (from .env or TMDB website)
TMDB_TEST_SESSION_ID=""

# Required: Your TMDB account ID (numeric)
TMDB_TEST_ACCOUNT_ID=""

# Optional: Your TMDB username (for display in tests)
TMDB_TEST_USERNAME=""